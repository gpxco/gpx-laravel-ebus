{
  "name": "mayvenstudios/gpx-laravel-ebus",
  "version": "1.0.1",
  "description": "GPX Event BUS",
  "keywords": [
    "ebus"
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,

  "require": {
    "php": ">=8.1",
    "danikdantist/queue-wrapper": "^2.0",
    "illuminate/support": "^8.0|^9.0|^10.0"
  },

  "autoload": {
    "psr-4": {
      "GPX\\EventBus\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "GPX\\EventBus\\EventBusServiceProvider"
      ],
      "aliases": {
        "Broadcaster": "GPX\\EventBus\\Facades\\Broadcaster"
      }
    }
  }
}